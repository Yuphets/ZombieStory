# For Vercel, add these in Project Settings -> Environment Variables.
# For local use, copy this file to .env.local or .env and fill in real values.
# The app accepts either DATABASE_URL or Vercel/Neon-style POSTGRES_URL variables.
DATABASE_URL=postgres://USER:PASSWORD@HOST/neondb?sslmode=require
POSTGRES_URL=postgres://USER:PASSWORD@HOST/neondb?sslmode=require
OPENAI_API_KEY=sk-...
