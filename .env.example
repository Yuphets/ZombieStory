# For Vercel, add these in Project Settings -> Environment Variables.
# For local use, copy this file to .env.local or .env and fill in real values.
# The app accepts either DATABASE_URL or Vercel/Neon-style POSTGRES_URL variables.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require
POSTGRES_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require
OPENAI_API_KEY=sk-...

# Optional low-level PG variables if your environment provides them instead of a URL.
PGHOST=
PGDATABASE=
PGUSER=
PGPASSWORD=
PGPORT=5432
PGSSLMODE=require
